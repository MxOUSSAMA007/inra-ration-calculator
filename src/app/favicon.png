<svg width="420" height="420" viewBox="0 0 420 420" xmlns="http://www.w3.org/2000/svg">

  <!-- Shield -->
  <path d="M210 40 L360 120 L330 320 L210 380 L90 320 L60 120 Z"
        fill="#1f6f3f" stroke="#14532d" stroke-width="8"/>

  <!-- Cow head circle -->
  <circle cx="210" cy="150" r="70" fill="white" stroke="#1f6f3f" stroke-width="6"/>

  <!-- Cow eyes -->
  <circle cx="190" cy="140" r="6" fill="black"/>
  <circle cx="230" cy="140" r="6" fill="black"/>

  <!-- Cow nose -->
  <ellipse cx="210" cy="170" rx="20" ry="12" fill="#ffb6b6"/>

  <!-- Banner -->
  <rect x="80" y="210" width="260" height="70" rx="20"
        fill="#1f6f3f"/>

  <!-- Title -->
  <text x="210" y="250"
        text-anchor="middle"
        font-size="22"
        font-weight="bold"
        fill="white"
        font-family="Arial">
    INRA RATION
  </text>

  <text x="210" y="275"
        text-anchor="middle"
        font-size="16"
        fill="#d4f4dd"
        font-family="Arial">
    CALCULATOR
  </text>

  <!-- Nutrition icons -->
  <circle cx="150" cy="320" r="18" fill="#facc15"/>
  <text x="150" y="325" text-anchor="middle" font-size="10" font-weight="bold">UFL</text>

  <circle cx="210" cy="320" r="18" fill="#86efac"/>
  <text x="210" y="325" text-anchor="middle" font-size="10" font-weight="bold">PDIN</text>

  <circle cx="270" cy="320" r="18" fill="#60a5fa"/>
  <text x="270" y="325" text-anchor="middle" font-size="10" font-weight="bold">PDIE</text>

</svg>
